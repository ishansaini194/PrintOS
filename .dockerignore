# Keep the build context small and never ship local/secret files into the image.
.git
.gitignore
.env
*.env

# Local runtime artifacts (agent-side + stored uploads)
uploads/
printos-agent.db
printos-token
printers.json

# Infra files not needed inside the image
Dockerfile
docker-compose.yml
RUN.md

# Editor/OS cruft
.DS_Store
.vscode/
.idea/
