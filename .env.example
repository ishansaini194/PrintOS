# NOTE: under docker-compose the cloud service overrides DB_HOST/DB_PORT/DB_USER/
# DB_PASSWORD/DB_NAME and PRINTOS_PDF_DIR (to reach the `db` service and the PDF
# volume). The values below are for running the binary directly; for compose you
# only need to fill the secrets (PRINTOS_ADMIN_KEY, RAZORPAY_*).
PORT=8080
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=printos
DB_PORT=5432
PRINTOS_PUBLIC_URL=http://localhost:8080
PRINTOS_CORS_ORIGIN=http://localhost:5173   # browser UI origin allowed by CORS
PRINTOS_ADMIN_KEY=            # set a long random secret; required for /admin routes
PRINTOS_MAX_UPLOAD_BYTES=52428800   # 50MB — max accepted upload size
PRINTOS_PDF_DIR=uploads/jobs        # where cleaned job PDFs are stored on disk
# PRINTOS_HOLD_TTL=30m                # hold window before a paid job expires
# PRINTOS_EXPIRY_SWEEP_INTERVAL=5m    # how often the expiry/refund sweeper runs
PRINTOS_CLOUD_WS=ws://localhost:8080/agent
PRINTOS_UPDATE_URL=http://localhost:8080/agent/latest
PRINTOS_PROVISION_URL=http://localhost:8080/agent/provision
PRINTOS_SETUP_CODE=        # paste once on first install; blank after provisioned
PRINTOS_TOKEN_FILE=printos-token
PRINTOS_PRINTERS_FILE=printers.json   # detected printers + mono/color tags (written on first run)
PRINTOS_PRINTER=
PRINTOS_SUMATRA=SumatraPDF.exe
PRINTOS_DB=printos-agent.db

# Razorpay (cloud-side; the secret must NEVER reach the UI)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
